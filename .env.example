# Local development origin. API_URL is server-only; do not rename it to
# NEXT_PUBLIC_API_URL unless you intentionally want to expose it to the browser.
LOCAL_HTTPS=true
API_URL=https://localhost:3000

# Server-only secrets. Copy this file to .env.local and fill values locally.
GROQ_API_KEY=
GROQ_TTS_MODEL=canopylabs/orpheus-v1-english
GROQ_TTS_VOICE=autumn

# Optional fallback AI providers. Groq is primary for chat, transcription, and
# text-to-speech; if a request to Groq is unconfigured, rate-limited, or
# erroring, the server automatically falls through to these in order
# (OpenAI, then Anthropic for chat text only). Leave blank to run on Groq
# only — this is purely additive reliability, not a required setup step.
OPENAI_API_KEY=
OPENAI_FALLBACK_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5

# Stripe billing (Plus/Premium subscriptions). Both required for
# app/api/billing/* — checkout/portal return 503 and the webhook returns 503
# until both are set. Get STRIPE_SECRET_KEY from the Stripe Dashboard (test
# mode is fine for local dev). STRIPE_WEBHOOK_SECRET comes from creating an
# endpoint at <your-domain>/api/billing/webhook in the Stripe Dashboard (or
# `stripe listen --forward-to localhost:3000/api/billing/webhook` locally),
# subscribed to: customer.subscription.created, customer.subscription.updated,
# customer.subscription.deleted. No publishable key is needed — checkout uses
# a server-redirect Stripe Checkout Session, not client-side Stripe.js.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Supabase. SUPABASE_URL + SUPABASE_ANON_KEY power auth/memory (user-scoped RLS).
# SUPABASE_SERVICE_ROLE_KEY is server-only and required for server-authoritative
# writes (Air wallet, Apex progression). Never expose it to the client. Without
# it, server-backed Apex/social endpoints return 503. Apply supabase/migrations first.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only administrator credentials. Store only a scrypt salt:hash value.
AIRGPT_ADMIN_USERNAME=
AIRGPT_ADMIN_PASSWORD_HASH=

# Google Drive integration (Integrations page). Create an OAuth 2.0 Web
# application client in Google Cloud Console (APIs & Services > Credentials)
# with redirect URI <your-domain>/api/integrations/google/callback (add both
# your local dev origin and your production domain). Requires the Drive API
# enabled and drive.readonly + drive.metadata.readonly scopes on the OAuth
# consent screen. Leave blank to keep Google Drive showing as not set up.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
